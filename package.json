{
  "name": "lint-reporter",
  "version": "1.0.0",
  "description": "GitHub Action – Lint json to Job Summary",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun build src/index.ts --target=node --outfile=dist/index.js --minify",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "lint": "oxlint src",
    "test": "bun test"
  },
  "dependencies": {
    "@actions/core": "^3.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24"
  }
}
